# Experiment Platform API Keys
#
# Add keys for the vendors you want to test. You don't need all of them.
# The setup page (http://localhost:8000) can also configure these for you.
#
# Never commit this file to git.

# Anthropic — Claude models (Opus, Sonnet, Haiku)
ANTHROPIC_API_KEY=

# OpenAI — GPT models (GPT-4o, GPT-5.4, etc.)
OPENAI_API_KEY=

# Google — Gemini models (Gemini Flash, Gemini Pro)
GOOGLE_API_KEY=

# xAI — Grok models
XAI_API_KEY=

# Together AI — Open-weight models via OpenAI-compatible API (Llama, Mistral, etc.)
TOGETHER_API_KEY=
