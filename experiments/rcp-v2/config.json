{
  "name": "rcp-v2",
  "description": "Relational Consistency Probing v2. 18 concepts per domain, brief cultural framings, combined rating and explanation probes.",
  "version": "2.0",

  "stimuli_path": "stimuli/probes-v2.json",

  "prompt_templates": {
    "unframed": "stimuli/templates/unframed.txt",
    "individualist": "stimuli/templates/individualist.txt",
    "collectivist": "stimuli/templates/collectivist.txt",
    "hierarchical": "stimuli/templates/hierarchical.txt",
    "egalitarian": "stimuli/templates/egalitarian.txt",
    "geometric": "stimuli/templates/geometric.txt",
    "glorbic": "stimuli/templates/glorbic.txt"
  },

  "parameters": {
    "iterations": 5,
    "temperature": 0.7,
    "max_tokens": 500,
    "delay_seconds": 1.0
  },

  "parsed_schema": {
    "probe_id": "string",
    "domain_a": "string",
    "domain_b": "string",
    "pair_type": "string",
    "concept_a": "string",
    "concept_b": "string",
    "frame": "string",
    "rating": "number",
    "explanation": "string",
    "is_refusal": "boolean",
    "data_quality": "object"
  },

  "field_map": {
    "grouping_variable": "domain_a",
    "primary_score": "rating",
    "explanation_field": "explanation"
  }
}